rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permitimos leer y escribir en la coleccion de usuarios para que el registro funcione
    match /usuarios/{usuarioId} {
      allow read, write: if true;
    }

    // Para el resto de la base de datos, sí pedimos estar logueado
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
